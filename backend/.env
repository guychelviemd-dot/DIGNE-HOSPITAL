# ============================================================
# SGHL — Configuration développement local
# Copier ce fichier en .env et adapter les valeurs
# ============================================================

# Django Core
DEBUG=True
SECRET_KEY=sghl-dev-secret-key-change-in-production-2025

# Base de données (SQLite pour dev local, PostgreSQL pour prod)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Hôtes autorisés
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Email (console en dev, SMTP en prod)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@chu-conakry.gn

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Monitoring (optionnel)
GRAFANA_PASSWORD=admin123

# URL du portail patient (pour les emails)
PORTAL_URL=http://localhost:5173
